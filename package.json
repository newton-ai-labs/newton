{
  "name": "newton",
  "version": "1.0.0",
  "type": "module",
  "description": "Newton — an AI-native code editor (better than Cursor). Monaco + multi-provider LLM + agent mode + voice coding + NL terminal + one-click tests.",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/clear-ports.mjs",
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@monaco-editor/react": "^4.7.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.408.0",
    "monaco-editor": "^0.50.0",
    "nanoid": "^5.1.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^2.1.9",
    "react-syntax-highlighter": "^15.6.6",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.9"
  }
}
