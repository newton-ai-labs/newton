# Newton — environment configuration
# Copy to .env and fill in. All optional — app runs in demo mode without keys.

# Built-in demo AI requires no key. Set a provider in Settings to override.
NEWTON_PORT=8787

# Optional: default providers (can also be configured in-app Settings)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Restrict file browsing to this workspace root (default: current working dir)
NEWTON_WORKSPACE=