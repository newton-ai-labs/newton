# Newton — environment configuration
# Copy to .env and fill in. All optional — app runs in demo mode without keys.
#
# NOTE: Provider API keys are configured in-app via the Settings panel (⌘,)
# and stored in your browser's localStorage. They are sent to the local Newton
# server per-request, which proxies to the provider.
#
# The server-side env vars below are OPTIONAL and used only by the /api/health
# endpoint to report whether keys are present in the environment.

# Server
NEWTON_PORT=8787
# Restrict file browsing to this workspace root (default: current working dir)
NEWTON_WORKSPACE=

# Optional server-side keys (reported in /api/health; not required for app to work)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=

# Local providers (no key needed)
OLLAMA_BASE_URL=http://localhost:11434
LOCALAI_BASE_URL=http://localhost:8080/v1